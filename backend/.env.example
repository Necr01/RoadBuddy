# ================================================================
# RoadBuddy — Environment Variables
# Copy this file to .env and fill in all values before running.
# NEVER commit .env to Git.
# ================================================================

# Server
PORT=3001
NODE_ENV=development

# JWT — generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=REPLACE_WITH_LONG_RANDOM_STRING

# ── Database ──────────────────────────────────────────
# Option A: individual variables (local MySQL / Railway)
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_password_here
DB_NAME=roadbuddy
DB_SSL=false

# Option B: single connection URL (Railway auto-provides this)
# DATABASE_URL=mysql://user:password@host:port/dbname

# ── CORS ──────────────────────────────────────────────
# Comma-separated list of allowed frontend origins
# Use * for development only — set your real URL for production
ALLOWED_ORIGINS=http://localhost:3001,http://localhost:5500
